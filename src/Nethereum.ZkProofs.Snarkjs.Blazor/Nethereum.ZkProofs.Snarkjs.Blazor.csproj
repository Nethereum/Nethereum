<Project Sdk="Microsoft.NET.Sdk.Razor">
  <Import Project="$([MSBuild]::GetDirectoryNameOfFileAbove($(MSBuildThisFileDirectory), dir.props))\dir.props" />

  <PropertyGroup>
    <Description>Nethereum ZkProofs Snarkjs Blazor - Browser-based snarkjs proof generation via JS interop</Description>
    <AssemblyTitle>Nethereum.ZkProofs.Snarkjs.Blazor</AssemblyTitle>
    <Version>$(NethereumVersion)</Version>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <AssemblyName>Nethereum.ZkProofs.Snarkjs.Blazor</AssemblyName>
    <PackageId>Nethereum.ZkProofs.Snarkjs.Blazor</PackageId>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Nethereum.ZkProofs\Nethereum.ZkProofs.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.JSInterop" Version="8.0.0" />
  </ItemGroup>

  <PropertyGroup Condition=" '$(TargetFramework)' != 'net35' And '$(TargetUnityNet461AOT)' != 'true'">
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>..\..\NethereumKey.snk</AssemblyOriginatorKeyFile>
  </PropertyGroup>
  <ItemGroup Condition=" '$(TargetFramework)' != 'net35' And '$(TargetUnityNet461AOT)' != 'true'">
    <None Include="..\..\NethereumKey.snk" />
  </ItemGroup>

</Project>
