@page "/contracts"
@using Nethereum.Explorer.Services
@inject IContractQueryService ContractQuery
@inject IJSRuntime JS
@inject ExplorerLocalizer L
@inject ILogger<Contracts> Logger

<PageTitle>@L[ExplorerKeys.ContractList.Title] - Nethereum Explorer</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-file-earmark-code me-2"></i>@L[ExplorerKeys.ContractList.Title]</h4>
    <div class="d-flex align-items-center gap-2">
        <span class="explorer-subtitle">@(_totalCount?.ToString("N0") ?? "...") @L[ExplorerKeys.Shared.Total]</span>
        @if (_contracts != null && _contracts.Any())
        {
            <button class="btn btn-outline-secondary btn-sm" @onclick="ExportCsvAsync" title="@L[ExplorerKeys.Shared.ExportCsv]">
                <i class="bi bi-download me-1"></i>CSV
            </button>
        }
    </div>
</div>

@if (_contracts == null)
{
    <div class="card">
        <div class="card-body p-0">
            <SkeletonTable Rows="10" Columns="5" />
        </div>
    </div>
}
else if (!_contracts.Any())
{
    <EmptyState IconClass="bi bi-file-earmark-code" Title="@L[ExplorerKeys.ContractList.NoContractsIndexed]" Subtitle="@L[ExplorerKeys.ContractList.ContractsWillAppear]" />
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>@L[ExplorerKeys.Account.Address]</th>
                            <th>@L[ExplorerKeys.Table.Name]</th>
                            <th>@L[ExplorerKeys.ContractList.Creator]</th>
                            <th>@L[ExplorerKeys.ContractList.CreationTx]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var contract in _contracts)
                        {
                            <tr>
                                <td>
                                    <HexDisplay Value="@contract.Address" Link="@($"/contract/{contract.Address}")" MaxLength="18" ShowCopy="false" />
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(contract.Name))
                                    {
                                        <span class="text-color-primary">@contract.Name</span>
                                    }
                                    else
                                    {
                                        <span class="text-color-dim">—</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(contract.Creator))
                                    {
                                        <HexDisplay Value="@contract.Creator" Link="@($"/account/{contract.Creator}")" MaxLength="14" ShowCopy="false" />
                                    }
                                    else
                                    {
                                        <span class="text-color-dim">—</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(contract.TransactionHash))
                                    {
                                        <HexDisplay Value="@contract.TransactionHash" Link="@($"/transaction/{contract.TransactionHash}")" MaxLength="14" ShowCopy="false" />
                                    }
                                    else
                                    {
                                        <span class="text-color-dim">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <Pagination CurrentPage="@_page" HasMore="@_hasMore" TotalPages="@(_totalCount.HasValue ? (int)Math.Ceiling(_totalCount.Value / (double)PageSize) : 0)" OnPageChanged="@GoToPage" />
    </div>
}

@code {
    private List<IContractView>? _contracts;
    private int _page = 1;
    private bool _hasMore;
    private int? _totalCount;
    private const int PageSize = ExplorerConstants.DefaultPageSize;

    protected override async Task OnInitializedAsync() => await LoadPageAsync();

    private async Task GoToPage(int page)
    {
        _page = page;
        await LoadPageAsync();
    }

    private async Task LoadPageAsync()
    {
        try
        {
            _contracts = await ContractQuery.GetContractsPagedAsync(_page, PageSize);
            _hasMore = _contracts.Count == PageSize;
            _totalCount = await ContractQuery.GetTotalContractCountAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load contracts page {Page}", _page);
            _contracts ??= new();
        }
    }

    private async Task ExportCsvAsync()
    {
        if (_contracts == null) return;
        var csv = CsvExportService.ExportContracts(_contracts);
        await JS.InvokeVoidAsync("downloadCsv", $"contracts_page{_page}.csv", csv);
    }
}
