@page "/pending"
@using Microsoft.Extensions.Options
@using Nethereum.Explorer.Services
@inject IRpcQueryService Rpc
@inject ExplorerChainService ChainService
@inject ExplorerLocalizer L
@inject IOptions<ExplorerOptions> Options

<PageTitle>@L[ExplorerKeys.PendingTx.Title] - Nethereum Explorer</PageTitle>

@if (!Options.Value.EnablePendingTransactions)
{
    <EmptyState IconClass="bi bi-hourglass-split" Title="@L[ExplorerKeys.PendingTx.NotSupported]" Subtitle="@L[ExplorerKeys.PendingTx.NotSupportedSubtitle]" />
    return;
}

<Breadcrumb Items="@(new List<Breadcrumb.BreadcrumbItem> { new() { Label = L[ExplorerKeys.PendingTx.Title] } })" />

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-hourglass-split me-2"></i>@L[ExplorerKeys.PendingTx.Title]</h4>
    <button class="btn btn-outline-primary btn-sm" @onclick="RefreshAsync" disabled="@_loading">
        <i class="bi bi-arrow-clockwise me-1"></i>@L[ExplorerKeys.PendingTx.Refresh]
    </button>
</div>

@if (_loading)
{
    <LoadingSpinner Message="@L[ExplorerKeys.PendingTx.LoadingPending]" />
}
else if (_result != null && !_result.IsSupported)
{
    <EmptyState IconClass="bi bi-exclamation-triangle" Title="@L[ExplorerKeys.PendingTx.NotSupported]" Subtitle="@L[ExplorerKeys.PendingTx.NotSupportedSubtitle]" />
}
else if (_result != null)
{
    <ul class="nav nav-tabs mb-0">
        <li class="nav-item">
            <button class="nav-link @(_activeTab == "pending" ? "active" : "")" @onclick="@(() => _activeTab = "pending")">
                <i class="bi bi-hourglass me-1"></i>@L[ExplorerKeys.PendingTx.PendingTab]
                <span class="badge ms-1 explorer-badge explorer-badge-primary text-xs">@_result.Pending.Count</span>
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link @(_activeTab == "queued" ? "active" : "")" @onclick="@(() => _activeTab = "queued")">
                <i class="bi bi-clock-history me-1"></i>@L[ExplorerKeys.PendingTx.QueuedTab]
                <span class="badge ms-1 explorer-badge explorer-badge-primary text-xs">@_result.Queued.Count</span>
            </button>
        </li>
    </ul>

    <div class="card explorer-tab-card-body">
        <div class="card-body p-0">
            @{
                var items = _activeTab == "pending" ? _result.Pending : _result.Queued;
            }
            @if (!items.Any())
            {
                <EmptyState IconClass="bi bi-inbox"
                            Title="@(_activeTab == "pending" ? L[ExplorerKeys.PendingTx.NoPending] : L[ExplorerKeys.PendingTx.NoQueued])"
                            Subtitle="@L[ExplorerKeys.PendingTx.NoPendingSubtitle]" />
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>@L[ExplorerKeys.Table.TxHash]</th>
                                <th>@L[ExplorerKeys.Table.From]</th>
                                <th>@L[ExplorerKeys.Table.To]</th>
                                <th class="text-end">@L[ExplorerKeys.Table.Value]</th>
                                <th class="text-end">@L[ExplorerKeys.Table.Gas]</th>
                                <th class="text-end">Nonce</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var tx in items)
                            {
                                <tr>
                                    <td><HexDisplay Value="@tx.Hash" Link="@($"/transaction/{tx.Hash}")" MaxLength="16" ShowCopy="false" /></td>
                                    <td><HexDisplay Value="@tx.From" Link="@($"/account/{tx.From}")" MaxLength="16" ShowCopy="false" /></td>
                                    <td>
                                        @if (!string.IsNullOrEmpty(tx.To))
                                        {
                                            <HexDisplay Value="@tx.To" Link="@($"/account/{tx.To}")" MaxLength="16" ShowCopy="false" />
                                        }
                                        else
                                        {
                                            <span class="badge badge-success">CREATE</span>
                                        }
                                    </td>
                                    <td class="text-end font-monospace text-color-primary">@ExplorerFormatUtils.FormatEth(tx.Value) @ChainService.CurrencySymbol</td>
                                    <td class="text-end font-monospace explorer-subtitle">@ExplorerFormatUtils.FormatGwei(tx.GasPrice) Gwei</td>
                                    <td class="text-end font-monospace explorer-subtitle">@ExplorerFormatUtils.ParseBigInteger(tx.Nonce)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@code {
    private PendingTransactionsResult? _result;
    private bool _loading = true;
    private string _activeTab = "pending";

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        try
        {
            _result = await Rpc.GetPendingTransactionsAsync();
        }
        catch
        {
            _result = new PendingTransactionsResult();
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task RefreshAsync()
    {
        await LoadAsync();
    }
}
