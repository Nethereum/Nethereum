@page "/not-found"
@inject ExplorerLocalizer L

<PageTitle>Not Found - Nethereum Explorer</PageTitle>

<div class="text-center py-5">
    <i class="bi bi-exclamation-triangle display-1 text-muted"></i>
    <h3 class="mt-3">@L[ExplorerKeys.Errors.PageNotFound]</h3>
    <p class="text-muted">@L[ExplorerKeys.Errors.PageNotFoundMessage]</p>
    <a href="/" class="btn btn-primary mt-2">
        <i class="bi bi-house me-2"></i>@L[ExplorerKeys.Errors.BackToDashboard]
    </a>
</div>
