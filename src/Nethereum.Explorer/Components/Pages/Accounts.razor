@page "/accounts"
@using Nethereum.Explorer.Services
@inject IAccountQueryService AccountQuery
@inject ExplorerLocalizer L
@inject ILogger<Accounts> Logger

<PageTitle>@L[ExplorerKeys.AccountList.Title] - Nethereum Explorer</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0"><i class="bi bi-people me-2"></i>@L[ExplorerKeys.AccountList.Title]</h4>
    <div class="d-flex align-items-center gap-2">
        <span class="explorer-subtitle">@(_totalCount?.ToString("N0") ?? "...") @L[ExplorerKeys.Shared.Total]</span>
    </div>
</div>

@if (_accounts == null)
{
    <div class="card">
        <div class="card-body p-0">
            <SkeletonTable Rows="10" Columns="3" />
        </div>
    </div>
}
else if (!_accounts.Any())
{
    <EmptyState IconClass="bi bi-people" Title="@L[ExplorerKeys.AccountList.NoAccountsIndexed]" Subtitle="@L[ExplorerKeys.AccountList.AccountsWillAppear]" />
}
else
{
    <div class="card">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>@L[ExplorerKeys.Account.Address]</th>
                            <th>@L[ExplorerKeys.Table.Txns]</th>
                            <th>@L[ExplorerKeys.Table.Type]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var account in _accounts)
                        {
                            <tr>
                                <td>
                                    <HexDisplay Value="@account.Address" Link="@($"/account/{account.Address}")" MaxLength="18" ShowCopy="false" />
                                </td>
                                <td>
                                    <span class="badge badge-info">@account.TransactionCount.ToString("N0")</span>
                                </td>
                                <td>
                                    @if (account.IsContract)
                                    {
                                        <span class="badge explorer-badge explorer-badge-info">
                                            <i class="bi bi-file-earmark-code me-1"></i>@L[ExplorerKeys.Table.Contract]
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge explorer-badge explorer-badge-primary">
                                            <i class="bi bi-person me-1"></i>@L[ExplorerKeys.AccountList.EOA]
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <Pagination CurrentPage="@_page" HasMore="@_hasMore" TotalPages="@(_totalCount.HasValue ? (int)Math.Ceiling(_totalCount.Value / (double)PageSize) : 0)" OnPageChanged="@GoToPage" />
    </div>
}

@code {
    private List<AccountSummary>? _accounts;
    private int _page = 1;
    private bool _hasMore;
    private int? _totalCount;
    private const int PageSize = ExplorerConstants.DefaultPageSize;

    protected override async Task OnInitializedAsync() => await LoadPageAsync();

    private async Task GoToPage(int page)
    {
        _page = page;
        await LoadPageAsync();
    }

    private async Task LoadPageAsync()
    {
        try
        {
            _accounts = await AccountQuery.GetAccountsPagedAsync(_page, PageSize);
            _hasMore = _accounts.Count == PageSize;
            _totalCount = await AccountQuery.GetTotalAccountCountAsync();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load accounts page {Page}", _page);
            _accounts ??= new();
        }
    }
}
