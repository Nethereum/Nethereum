@if (Logs != null && Logs.Any())
{
    <div class="card mb-3">
        <div class="card-header bg-transparent d-flex align-items-center">
            <h6 class="mb-0"><i class="bi bi-journal-text me-2"></i>@L[ExplorerKeys.TransactionDetail.EventLogs]</h6>
            <span class="badge ms-2 explorer-badge explorer-badge-primary">@Logs.Count</span>
        </div>
        <div class="card-body p-0">
            @for (int i = 0; i < Logs.Count; i++)
            {
                var log = Logs[i];
                var decoded = i < DecodedLogs.Count ? DecodedLogs[i] : null;
                <EventLogEntry Log="log" Decoded="decoded" />
            }
        </div>
    </div>
}

@code {
    [Parameter] public List<ITransactionLogView>? Logs { get; set; }
    [Parameter, EditorRequired] public List<DecodedEventLog> DecodedLogs { get; set; } = new();
    [Parameter, EditorRequired] public ExplorerLocalizer L { get; set; } = default!;
}
