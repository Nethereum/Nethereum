@if (TokenTransfers.Any())
{
    <div class="card mb-3">
        <div class="card-header bg-transparent d-flex align-items-center">
            <h6 class="mb-0"><i class="bi bi-coin me-2"></i>@L[ExplorerKeys.TransactionDetail.TokenTransfers]</h6>
            <span class="badge ms-2 explorer-badge explorer-badge-primary">@TokenTransfers.Count</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>@L[ExplorerKeys.Table.From]</th>
                            <th></th>
                            <th>@L[ExplorerKeys.Table.To]</th>
                            <th class="text-end">@L[ExplorerKeys.Table.Amount]</th>
                            <th>@L[ExplorerKeys.Table.Token]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var transfer in TokenTransfers)
                        {
                            var fromAddr = ExplorerFormatUtils.ExtractAddressFromTopic(transfer.IndexVal1);
                            var toAddr = ExplorerFormatUtils.ExtractAddressFromTopic(transfer.IndexVal2);
                            var decimals = TokenDecimals.GetValueOrDefault(transfer.Address ?? "", 18);
                            var amount = ExplorerFormatUtils.FormatTokenAmount(transfer.Data, decimals);
                            <tr>
                                <td><HexDisplay Value="@fromAddr" Link="@($"/account/{fromAddr}")" MaxLength="14" ShowCopy="false" /></td>
                                <td class="text-center px-0"><i class="bi bi-arrow-right text-color-dim"></i></td>
                                <td><HexDisplay Value="@toAddr" Link="@($"/account/{toAddr}")" MaxLength="14" ShowCopy="false" /></td>
                                <td class="text-end font-monospace text-color-primary">@amount</td>
                                <td><HexDisplay Value="@transfer.Address" Link="@($"/contract/{transfer.Address}")" MaxLength="14" ShowCopy="false" /></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    [Parameter, EditorRequired] public List<ITransactionLogView> TokenTransfers { get; set; } = new();
    [Parameter, EditorRequired] public Dictionary<string, int> TokenDecimals { get; set; } = new();
    [Parameter, EditorRequired] public ExplorerLocalizer L { get; set; } = default!;
}
