<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="$([MSBuild]::GetDirectoryNameOfFileAbove($(MSBuildThisFileDirectory), dir.props))\dir.props" />

  <PropertyGroup>
    <Description>Nethereum PrivacyPools Circuits - Embedded circuit artifacts (wasm, zkey, vk) for Privacy Pools commitment and withdrawal proofs</Description>
    <AssemblyTitle>Nethereum.PrivacyPools.Circuits</AssemblyTitle>
    <Version>$(NethereumVersion)</Version>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <AssemblyName>Nethereum.PrivacyPools.Circuits</AssemblyName>
    <PackageId>Nethereum.PrivacyPools.Circuits</PackageId>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="" Condition="Exists('README.md')" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Nethereum.ZkProofs\Nethereum.ZkProofs.csproj" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="circuits\**\*" />
  </ItemGroup>

  <PropertyGroup Condition=" '$(TargetFramework)' != 'net35' And '$(TargetUnityNet461AOT)' != 'true'">
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>..\..\NethereumKey.snk</AssemblyOriginatorKeyFile>
  </PropertyGroup>
  <ItemGroup Condition=" '$(TargetFramework)' != 'net35' And '$(TargetUnityNet461AOT)' != 'true'">
    <None Include="..\..\NethereumKey.snk" />
  </ItemGroup>

</Project>
