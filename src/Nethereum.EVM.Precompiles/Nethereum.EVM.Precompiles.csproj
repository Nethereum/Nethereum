<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="$([MSBuild]::GetDirectoryNameOfFileAbove($(MSBuildThisFileDirectory), dir.props))\dir.props" />
  <PropertyGroup>
    <Description>Standard Ethereum precompile implementations (1-9) for Nethereum EVM.</Description>
    <AssemblyTitle>Nethereum.EVM.Precompiles</AssemblyTitle>
    <VersionPrefix>$(NethereumVersion)</VersionPrefix>
    <TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
    <AssemblyName>Nethereum.EVM.Precompiles</AssemblyName>
    <PackageId>Nethereum.EVM.Precompiles</PackageId>
    <PackageTags>Ethereum;EVM;Precompile;EcRecover;SHA256;RIPEMD160;ModExp;BN128;Blake2f</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Nethereum.EVM.Core\Nethereum.EVM.Core.csproj" />
    <ProjectReference Include="..\Nethereum.Signer\Nethereum.Signer.csproj" />
  </ItemGroup>
  <PropertyGroup Condition=" '$(TargetFramework)' != 'net35' And '$(TargetUnityNet461AOT)' != 'true'">
    <SignAssembly>true</SignAssembly>
    <AssemblyOriginatorKeyFile>..\..\NethereumKey.snk</AssemblyOriginatorKeyFile>
  </PropertyGroup>
  <ItemGroup Condition=" '$(TargetFramework)' != 'net35' And '$(TargetUnityNet461AOT)' != 'true'">
    <None Include="..\..\NethereumKey.snk" />
  </ItemGroup>
</Project>
