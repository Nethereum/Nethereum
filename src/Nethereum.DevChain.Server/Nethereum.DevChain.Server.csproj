<Project Sdk="Microsoft.NET.Sdk.Web">
  <Import Project="$([MSBuild]::GetDirectoryNameOfFileAbove($(MSBuildThisFileDirectory), dir.props))\dir.props" />

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>$(ServerFrameworks)</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Nethereum.DevChain.Server</RootNamespace>

    <!-- AOT Configuration
    <PublishAot>true</PublishAot>
    <IsAotCompatible>true</IsAotCompatible>
    -->
    <InvariantGlobalization>true</InvariantGlobalization>
    <EnableRequestDelegateGenerator>false</EnableRequestDelegateGenerator>

    <!-- Tool Configuration -->
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>nethereum-devchain</ToolCommandName>
    <IsPackable>true</IsPackable>

    <!-- Package Metadata -->
    <Description>Nethereum DevChain Server - Local Ethereum development node with JSON-RPC server. Similar to Ganache, Hardhat Network, or Anvil but built in .NET.</Description>
    <AssemblyTitle>Nethereum.DevChain.Server</AssemblyTitle>
    <Version>$(NethereumVersion)</Version>
    <AssemblyName>Nethereum.DevChain.Server</AssemblyName>
    <PackageId>Nethereum.DevChain.Server</PackageId>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Nethereum.DevChain\Nethereum.DevChain.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.CommandLine" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="10.0.0" />
  </ItemGroup>

  <ItemGroup>
    <TrimmerRootAssembly Include="Nethereum.Contracts" />
    <TrimmerRootAssembly Include="Nethereum.ABI" />
    <TrimmerRootAssembly Include="Nethereum.Hex" />
    <TrimmerRootAssembly Include="Nethereum.DevChain.Server" />
  </ItemGroup>

</Project>
