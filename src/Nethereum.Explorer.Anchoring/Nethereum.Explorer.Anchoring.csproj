<Project Sdk="Microsoft.NET.Sdk.Razor">

  <Import Project="$([MSBuild]::GetDirectoryNameOfFileAbove($(MSBuildThisFileDirectory), dir.props))\dir.props" />

  <PropertyGroup>
    <Description>Nethereum.Explorer.Anchoring — Pluggable Blazor Server pages for AppChain anchoring monitoring. Razor Class Library — add to any Nethereum Explorer instance via AddAdditionalAssemblies.</Description>
    <AssemblyTitle>Nethereum.Explorer.Anchoring</AssemblyTitle>
    <Version>$(NethereumVersionPreview)</Version>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>Nethereum.Explorer.Anchoring</AssemblyName>
    <PackageId>Nethereum.Explorer.Anchoring</PackageId>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Nethereum.Explorer\Nethereum.Explorer.csproj" />
    <ProjectReference Include="..\Nethereum.AppChain.Anchoring.Postgres\Nethereum.AppChain.Anchoring.Postgres.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Update="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

</Project>
