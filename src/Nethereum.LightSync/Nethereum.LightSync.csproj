<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="$([MSBuild]::GetDirectoryNameOfFileAbove($(MSBuildThisFileDirectory), dir.props))\dir.props" />
  <PropertyGroup>
    <Description>Nethereum LightSync - DevP2P block sync with light client finality, feeds CoreChain storage and BlockchainProcessing indexer</Description>
    <AssemblyTitle>Nethereum.LightSync</AssemblyTitle>
    <Version>$(NethereumVersion)</Version>
    <TargetFrameworks>$(CoreChainFrameworks)</TargetFrameworks>
    <AssemblyName>Nethereum.LightSync</AssemblyName>
    <PackageId>Nethereum.LightSync</PackageId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="[8.0.0,)" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Nethereum.DevP2P.Eth\Nethereum.DevP2P.Eth.csproj" />
    <ProjectReference Include="..\Nethereum.CoreChain\Nethereum.CoreChain.csproj" />
    <ProjectReference Include="..\Nethereum.BlockchainProcessing\Nethereum.BlockchainProcessing.csproj" />
    <ProjectReference Include="..\Nethereum.Consensus.LightClient\Nethereum.Consensus.LightClient.csproj" />
    <ProjectReference Include="..\Nethereum.Beaconchain\Nethereum.Beaconchain.csproj" />
  </ItemGroup>

</Project>
