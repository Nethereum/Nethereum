<Project Sdk="Microsoft.NET.Sdk.Web">
  <Import Project="$([MSBuild]::GetDirectoryNameOfFileAbove($(MSBuildThisFileDirectory), dir.props))\dir.props" />

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>$(ServerFrameworks)</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Nethereum.MainnetChain.Server</RootNamespace>

    <InvariantGlobalization>true</InvariantGlobalization>
    <EnableRequestDelegateGenerator>false</EnableRequestDelegateGenerator>

    <PackAsTool>true</PackAsTool>
    <ToolCommandName>nethereum-mainnetchain</ToolCommandName>
    <IsPackable>true</IsPackable>

    <Description>Nethereum MainnetChain Server - read-only mainnet follower host composing MainnetChainNode (CoreChain) + DevP2P sync orchestration + optional beacon LightClient consensus gate. Serves eth_/net_/web3_ JSON-RPC against locally-followed state.</Description>
    <AssemblyTitle>Nethereum.MainnetChain.Server</AssemblyTitle>
    <Version>$(NethereumVersion)</Version>
    <AssemblyName>Nethereum.MainnetChain.Server</AssemblyName>
    <PackageId>Nethereum.MainnetChain.Server</PackageId>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="" />
    <EmbeddedResource Include="Resources\MainnetGenesis.json" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Nethereum.CoreChain\Nethereum.CoreChain.csproj" />
    <ProjectReference Include="..\Nethereum.CoreChain.RocksDB\Nethereum.CoreChain.RocksDB.csproj" />
    <ProjectReference Include="..\Nethereum.DevP2P\Nethereum.DevP2P.csproj" />
    <ProjectReference Include="..\Nethereum.DevP2P.Sync\Nethereum.DevP2P.Sync.csproj" />
    <ProjectReference Include="..\Nethereum.Consensus.LightClient\Nethereum.Consensus.LightClient.csproj" />
    <ProjectReference Include="..\Nethereum.Model\Nethereum.Model.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Configuration.CommandLine" Version="10.0.0" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" Version="10.0.0" />
  </ItemGroup>

</Project>
