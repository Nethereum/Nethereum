<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="$([MSBuild]::GetDirectoryNameOfFileAbove($(MSBuildThisFileDirectory), dir.props))\dir.props" />
  <PropertyGroup>
    <Description>Nethereum DevP2P Eth - eth/68 wire protocol messages and peer API</Description>
    <AssemblyTitle>Nethereum.DevP2P.Eth</AssemblyTitle>
    <Version>$(NethereumVersion)</Version>
    <TargetFrameworks>$(CoreChainFrameworks)</TargetFrameworks>
    <AssemblyName>Nethereum.DevP2P.Eth</AssemblyName>
    <PackageId>Nethereum.DevP2P.Eth</PackageId>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Nethereum.DevP2P\Nethereum.DevP2P.csproj" />
    <ProjectReference Include="..\Nethereum.Model\Nethereum.Model.csproj" />
    <ProjectReference Include="..\Nethereum.Hex\Nethereum.Hex.csproj" />
    <ProjectReference Include="..\Nethereum.RLP\Nethereum.RLP.csproj" />
  </ItemGroup>

</Project>
