<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Nethereum.AppChain.Node</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\shared\Nethereum.Aspire.ServiceDefaults\Nethereum.Aspire.ServiceDefaults.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseProjectReferences)' == 'true'">
    <ProjectReference Include="..\..\..\src\Nethereum.DevChain\Nethereum.DevChain.csproj" />
    <ProjectReference Include="..\..\..\src\Nethereum.CoreChain\Nethereum.CoreChain.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseProjectReferences)' != 'true'">
    <PackageReference Include="Nethereum.DevChain" Version="6.*" />
    <PackageReference Include="Nethereum.CoreChain" Version="6.*" />
  </ItemGroup>

</Project>
