@using Nethereum.Explorer.Components.Layout

<Router AppAssembly="typeof(Nethereum.Explorer.Components.Routes).Assembly"
        AdditionalAssemblies="new[] { typeof(Nethereum.Explorer.Anchoring.Services.IAnchorExplorerService).Assembly }">
    <Found Context="routeData">
        <RouteView RouteData="routeData" DefaultLayout="typeof(MainLayout)" />
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
    <NotFound>
        <LayoutView Layout="typeof(MainLayout)">
            <Nethereum.Explorer.Components.Pages.NotFound />
        </LayoutView>
    </NotFound>
</Router>
