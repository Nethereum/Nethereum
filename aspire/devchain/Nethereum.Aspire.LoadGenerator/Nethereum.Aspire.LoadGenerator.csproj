<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Nethereum.Aspire.LoadGenerator</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="OpenTelemetry.Extensions.Hosting" Version="1.12.0" />
    <PackageReference Include="OpenTelemetry.Exporter.OpenTelemetryProtocol" Version="1.12.0" />
    <PackageReference Include="Microsoft.Extensions.Http" Version="$(MicrosoftExtensionsVersion)" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\shared\Nethereum.Aspire.ServiceDefaults\Nethereum.Aspire.ServiceDefaults.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseProjectReferences)' == 'true'">
    <ProjectReference Include="..\..\..\src\Nethereum.Web3\Nethereum.Web3.csproj" />
    <ProjectReference Include="..\..\..\src\Nethereum.Signer\Nethereum.Signer.csproj" />
    <ProjectReference Include="..\..\..\src\Nethereum.Contracts\Nethereum.Contracts.csproj" />
    <ProjectReference Include="..\..\..\src\Nethereum.Mud.Contracts\Nethereum.Mud.Contracts.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseProjectReferences)' != 'true'">
    <PackageReference Include="Nethereum.Web3" Version="5.*" />
    <PackageReference Include="Nethereum.Signer" Version="5.*" />
    <PackageReference Include="Nethereum.Contracts" Version="5.*" />
    <PackageReference Include="Nethereum.Mud.Contracts" Version="5.*" />
  </ItemGroup>

</Project>
