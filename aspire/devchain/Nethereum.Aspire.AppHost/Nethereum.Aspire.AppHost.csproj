<Project Sdk="Microsoft.NET.Sdk">

  <Sdk Name="Aspire.AppHost.Sdk" Version="13.1.1" />

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsAspireHost>true</IsAspireHost>
    <UserSecretsId>nethereum-aspire-apphost</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Aspire.Hosting.AppHost" Version="$(AspireVersion)" />
    <PackageReference Include="Aspire.Hosting.PostgreSQL" Version="$(AspireVersion)" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\Nethereum.Aspire.DevChain\Nethereum.Aspire.DevChain.csproj" />
    <ProjectReference Include="..\Nethereum.Aspire.Indexer\Nethereum.Aspire.Indexer.csproj" />
    <ProjectReference Include="..\Nethereum.Aspire.Bundler\Nethereum.Aspire.Bundler.csproj" />
    <ProjectReference Include="..\Nethereum.Aspire.Explorer\Nethereum.Aspire.Explorer.csproj" />
    <ProjectReference Include="..\Nethereum.Aspire.LoadGenerator\Nethereum.Aspire.LoadGenerator.csproj" />
  </ItemGroup>

</Project>
