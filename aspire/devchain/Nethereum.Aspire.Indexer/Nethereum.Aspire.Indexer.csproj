<Project Sdk="Microsoft.NET.Sdk.Worker">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Nethereum.Aspire.Indexer</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\shared\Nethereum.Aspire.ServiceDefaults\Nethereum.Aspire.ServiceDefaults.csproj" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.0.2" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseProjectReferences)' == 'true'">
    <ProjectReference Include="..\..\..\src\Nethereum.BlockchainStorage.Processors.Postgres\Nethereum.BlockchainStorage.Processors.Postgres.csproj" />
    <ProjectReference Include="..\..\..\src\Nethereum.BlockchainStorage.Token.Postgres\Nethereum.BlockchainStorage.Token.Postgres.csproj" />
    <ProjectReference Include="..\..\..\src\Nethereum.Mud.Repositories.Postgres\Nethereum.Mud.Repositories.Postgres.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseProjectReferences)' != 'true'">
    <PackageReference Include="Nethereum.BlockchainStorage.Processors.Postgres" Version="5.*" />
    <PackageReference Include="Nethereum.BlockchainStorage.Token.Postgres" Version="5.*" />
    <PackageReference Include="Nethereum.Mud.Repositories.Postgres" Version="5.*" />
  </ItemGroup>

</Project>
