<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Nethereum.Aspire.Explorer</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\shared\Nethereum.Aspire.ServiceDefaults\Nethereum.Aspire.ServiceDefaults.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseProjectReferences)' == 'true'">
    <ProjectReference Include="..\..\..\src\Nethereum.Explorer\Nethereum.Explorer.csproj" />
    <ProjectReference Include="..\..\..\src\Nethereum.BlockchainStore.Postgres\Nethereum.BlockchainStore.Postgres.csproj" />
    <ProjectReference Include="..\..\..\src\Nethereum.BlockchainStorage.Token.Postgres\Nethereum.BlockchainStorage.Token.Postgres.csproj" />
    <ProjectReference Include="..\..\..\src\Nethereum.Mud.Repositories.Postgres\Nethereum.Mud.Repositories.Postgres.csproj" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseProjectReferences)' != 'true'">
    <PackageReference Include="Nethereum.Explorer" Version="5.*" />
    <PackageReference Include="Nethereum.BlockchainStore.Postgres" Version="5.*" />
    <PackageReference Include="Nethereum.BlockchainStorage.Token.Postgres" Version="5.*" />
    <PackageReference Include="Nethereum.Mud.Repositories.Postgres" Version="5.*" />
  </ItemGroup>

</Project>
