{
  "$schema": "http://json.schemastore.org/template",
  "author": "Nethereum",
  "classifications": ["Aspire", "Blockchain", "Ethereum", "DevChain"],
  "identity": "Nethereum.DevChain.Aspire",
  "name": "Nethereum DevChain Aspire Solution",
  "shortName": "nethereum-devchain",
  "description": "An Aspire-orchestrated solution with a Nethereum DevChain node, blockchain indexer (Postgres), and Explorer UI.",
  "defaultName": "NethereumDevChain",
  "preferNameDirectory": true,
  "tags": {
    "language": "C#",
    "type": "solution"
  },
  "sourceName": "NethereumDevChain",
  "symbols": {
    "NethereumVersion": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "6.0.4",
      "description": "Nethereum NuGet package version",
      "replaces": "NETHEREUM_VERSION"
    },
    "ChainId": {
      "type": "parameter",
      "datatype": "int",
      "defaultValue": "31337",
      "description": "Chain ID for the DevChain",
      "replaces": "CHAIN_ID_VALUE"
    },
    "AspireVersion": {
      "type": "parameter",
      "datatype": "string",
      "defaultValue": "13.1.1",
      "description": "Aspire SDK and hosting package version",
      "replaces": "ASPIRE_VERSION"
    }
  },
  "sources": [
    {
      "modifiers": [
        {
          "exclude": [
            "**/bin/**",
            "**/obj/**",
            "**/.vs/**"
          ]
        }
      ]
    }
  ]
}
