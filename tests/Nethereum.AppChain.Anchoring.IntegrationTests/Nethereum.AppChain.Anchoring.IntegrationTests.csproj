    <TargetFramework>net10.0</TargetFramework>
    <AssemblyName>Nethereum.AppChain.Anchoring.IntegrationTests</AssemblyName>
    <PackageId>Nethereum.AppChain.Anchoring.IntegrationTests</PackageId>
    <IsPackable>false</IsPackable>
